
' ============================================================
'  DIAGRAMA 1: PACIENTE
' ============================================================
@startuml Paciente
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EAF4FB
  BorderColor #2E86C1
  ArrowColor #1A5276
}
skinparam actor {
  BackgroundColor #D5F5E3
  BorderColor #1E8449
}

title Casos de Uso — Paciente\nSistema Gestor de Citas Hospitalarias

actor "Paciente" as PAC
actor "Sistema" as SIS #lightgray
actor "Recepcionista" as REC #lightyellow

rectangle "Sistema Gestor de Citas Hospitalarias" {

  ' --- Registro y Sesión ---
  usecase "UC01\nRegistrarse en el sistema" as UC01
  usecase "UC02\nIniciar sesión" as UC02
  usecase "UC03\nVisualizar datos personales" as UC03

  ' --- Agendar Cita ---
  usecase "UC04\nAgendar nueva cita" as UC04
  usecase "UC05\nSeleccionar especialidad" as UC05
  usecase "UC06\nSeleccionar doctor" as UC06
  usecase "UC07\nSeleccionar fecha disponible" as UC07
  usecase "UC08\nSeleccionar horario disponible" as UC08
  usecase "UC09\nVerificar disponibilidad del doctor" as UC09
  usecase "UC10\nVerificar cita pendiente\ncon el mismo doctor" as UC10
  usecase "UC11\nValidar rango de fecha\n(48 hrs - 3 meses)" as UC11
  usecase "UC12\nGenerar comprobante de cita\ny línea de pago" as UC12

  ' --- Pago ---
  usecase "UC13\nConfirmar pago\n(máx. 8 hrs)" as UC13

  ' --- Gestión de Citas ---
  usecase "UC14\nVisualizar historial de citas" as UC14
  usecase "UC15\nFiltrar citas por fecha o estatus" as UC15
  usecase "UC16\nCancelar cita" as UC16
  usecase "UC17\nAplicar política de cancelación\ny calcular reembolso" as UC17
}

' --- Relaciones Paciente ---
PAC --> UC01

' --- include / extend ---
UC05 ..> UC06 : <<include>>
UC04 ..> UC05 : <<include>>
UC11 ..> UC07 : <<include>>
UC07 ..> UC09 : <<include>>
UC04 ..> UC10 : <<include>>
UC08 ..> UC12  
UC02 ..> UC04 : <<extend>>
UC01 ..> UC02 : <<extend>>
UC02 ..> UC03 : <<extend>>
UC14 ..> UC15 : <<extend>>
UC04 ..> UC14 : <<extend>>
UC13 ..> UC16 : <<extend>>
UC12 ..> UC13 : <<extend>>
UC06 ..> UC11 : <<extend>>
UC09 ..> UC08 : <<extend>>

UC16 ..> UC17 : <<include>>

' --- Sistema como actor secundario ---
SIS --> UC09
SIS --> UC10
SIS --> UC11
SIS --> UC13
SIS --> UC17

' --- Actor compartido ---
REC --> UC16 : aprueba cancelación\n(si aplica doctor)

@enduml


' ============================================================
'  DIAGRAMA 2: DOCTOR (CORREGIDO - CON DEPENDENCIA DE SESIÓN)
' ============================================================
@startuml Doctor
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEF9E7
  BorderColor #D4AC0D
  ArrowColor #7D6608
}
skinparam actor {
  BackgroundColor #FDEBD0
  BorderColor #CA6F1E
}

title Casos de Uso — Doctor\nSistema Gestor de Citas Hospitalarias

actor "Doctor" as DOC
actor "Sistema" as SIS #lightgray
actor "Recepcionista" as REC #lightyellow

rectangle "Sistema Gestor de Citas Hospitalarias" {

  ' --- Sesión (UC base) ---
  usecase "D-UC01\nIniciar sesión" as UC01
  usecase "D-UC02\nCerrar sesión" as UC02

  ' --- Datos personales ---
  usecase "D-UC04\nVisualizar datos personales\n(solo lectura datos sensibles)" as UC04

  ' --- Citas del Doctor ---
  usecase "D-UC05\nVisualizar citas agendadas" as UC05
  usecase "D-UC06\nMarcar cita como Atendida\no No acudió" as UC06
  usecase "D-UC07\nSolicitar cancelación de cita\n(requiere aprobación)" as UC07
  usecase "D-UC08\nAprobación de cancelación\npor Recepcionista" as UC08

  ' --- Recetas ---
  usecase "D-UC09\nGenerar receta médica" as UC09
  usecase "D-UC10\nAgregar medicamentos\ny tratamiento" as UC10
  usecase "D-UC11\nAgregar diagnóstico\ny observaciones" as UC11

  ' --- Paciente ---
  usecase "D-UC12\nVisualizar datos del paciente" as UC12
  usecase "D-UC13\nVisualizar historial médico\ndel paciente" as UC13

  ' --- Horario ---
  usecase "D-UC14\nVisualizar jornada laboral\nasignada" as UC14
}

' --- Relaciones Doctor ---
DOC --> UC01
UC01 --> UC02

' --- TODOS los casos de uso EXTEND de Iniciar sesión ---
UC01 ..> UC04 : <<extend>>
UC01 ..> UC05 : <<extend>>
UC01 ..> UC06 : <<extend>>
UC01 ..> UC07 : <<extend>>
UC01 ..> UC09 : <<extend>>
UC01 ..> UC12 : <<extend>>
UC01 ..> UC13 : <<extend>>
UC01 ..> UC14 : <<extend>>

' --- include ---
UC07 ..> UC08 : <<include>>
UC09 ..> UC10 : <<include>>
UC09 ..> UC11 : <<include>>

' --- Actores secundarios ---
REC --> UC08 : aprueba/rechaza
SIS --> UC06 : registra el cambio de estatus
SIS --> UC05 : filtra citas por doctor


@enduml

' ============================================================
'  DIAGRAMA 3: RECEPCIONISTA (CORREGIDO - CON DEPENDENCIA DE SESIÓN)
' ============================================================
@startuml Recepcionista
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F4ECF7
  BorderColor #7D3C98
  ArrowColor #4A235A
}
skinparam actor {
  BackgroundColor #E8DAEF
  BorderColor #6C3483
}

title Casos de Uso — Recepcionista\nSistema Gestor de Citas Hospitalarias

actor "Recepcionista" as REC
actor "Sistema" as SIS #lightgray
actor "Admin" as ADM #lightcyan

rectangle "Sistema Gestor de Citas Hospitalarias" {

  ' --- Sesión (UC base) ---
  usecase "R-UC01\nIniciar sesión" as UC01
  usecase "R-UC02\nCerrar sesión" as UC02

  ' --- Gestión de Usuarios ---
  usecase "R-UC04\nDar de alta doctor" as UC04
  usecase "R-UC06\nDar de alta paciente" as UC06
  usecase "R-UC08\nDar de alta recepcionista" as UC08

  ' --- Citas ---
  usecase "R-UC10\nVisualizar citas del sistema" as UC10
  usecase "R-UC11\nCancelar cita (por paciente\no por doctor)" as UC11
  usecase "R-UC12\nAplicar política de cancelación\ny calcular reembolso" as UC12
  usecase "R-UC13\nAprobar cancelación\nsolicitada por doctor" as UC13

  ' --- Especialidades y Consultorios ---
  usecase "R-UC14\nGestionar especialidades" as UC14
  usecase "R-UC15\nGestionar consultorios" as UC15

  ' --- Restricciones implícitas ---
  usecase "R-UC18\nNO visualizar recetas médicas" as UC18
  usecase "R-UC19\nNO visualizar historial\nmédico del paciente" as UC19
}

' --- Relaciones Recepcionista ---
REC --> UC01
UC01 --> UC02

' --- TODOS los casos de uso EXTEND de Iniciar sesión ---
UC01 ..> UC04 : <<extend>>
UC01 ..> UC06 : <<extend>>
UC01 ..> UC08 : <<extend>>
UC01 ..> UC10 : <<extend>>
UC01 ..> UC11 : <<extend>>
UC01 ..> UC13 : <<extend>>
UC01 ..> UC14 : <<extend>>
UC01 ..> UC15 : <<extend>>
UC01 ..> UC18 : <<extend>>
UC01 ..> UC19 : <<extend>>

' --- include ---
UC11 ..> UC12 : <<include>>

' --- Actor compartido ---
ADM --> UC08 : también puede\ndar de alta

' --- Sistema como actor secundario ---
SIS --> UC04 : valida datos únicos (cédula, email)
SIS --> UC06 : valida datos únicos (email)
SIS --> UC18 : restringe acceso
SIS --> UC19 : restringe acceso
SIS --> UC10 : filtra por fecha, doctor, paciente

@enduml

' ============================================================
'  DIAGRAMA 4: FARMACÉUTICO (CORREGIDO - CON DEPENDENCIA DE SESIÓN)
' ============================================================
@startuml Farmaceutico
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #E8F8F5
  BorderColor #1ABC9C
  ArrowColor #0E6655
}
skinparam actor {
  BackgroundColor #D1F2EB
  BorderColor #148F77
}

title Casos de Uso — Farmacéutico (Perfil Opcional)\nSistema Gestor de Citas Hospitalarias

actor "Farmacéutico" as FAR #lightgreen
actor "Sistema" as SIS #lightgray
actor "Paciente" as PAC #lightgreen

rectangle "Sistema Gestor de Citas Hospitalarias" {

  ' --- Sesión (UC base) ---
  usecase "CF-UC01\nIniciar sesión" as UC01
  usecase "CF-UC02\nCerrar sesión" as UC02

  ' --- Farmacia / Inventario ---
  usecase "CF-UC04\nConsultar inventario\nde medicamentos" as UC04
  usecase "CF-UC05\nVender medicamento\n(sin receta)" as UC05
  usecase "CF-UC06\nVerificar stock disponible" as UC06
  usecase "CF-UC07\nActualizar inventario\ntras venta" as UC07
  usecase "CF-UC08\nVender medicamento\n(con receta médica)" as UC08
  usecase "CF-UC14\nPedir medicamento a proveedor\n(si no hay stock)" as UC14

  ' --- Servicios Extras ---
  usecase "CF-UC09\nRegistrar servicio extra\n(Inyección, Vacuna, Curación, etc.)" as UC09
  usecase "CF-UC10\nVender servicio extra\n(sin necesidad de cita)" as UC10

  ' --- Cobro ---
  usecase "CF-UC11\nGenerar cobro total\n(servicio, medicamento o ambos)" as UC11
  usecase "CF-UC12\nGenerar ticket de pago" as UC12
  usecase "CF-UC13\nRegistrar pago con tarjeta/efectivo" as UC13
}

' --- Relaciones ---
FAR --> UC01
UC01 --> UC02

' --- TODOS los casos de uso EXTEND de Iniciar sesión ---
UC01 ..> UC04 : <<extend>>
UC01 ..> UC05 : <<extend>>
UC01 ..> UC08 : <<extend>>
UC01 ..> UC09 : <<extend>>
UC09 ..> UC10 : <<extend>>

' --- include ---
UC04 ..> UC14 : <<include>>
UC05 ..> UC06 : <<include>>
UC13 ..> UC07 : <<include>>
UC08 ..> UC06 : <<include>>
UC11 ..> UC12 : <<include>>
UC12 ..> UC13 : <<include>>

' --- extend entre casos de cobro ---
UC10 ..> UC11 : <<extend>>
UC06 ..> UC11 : <<extend>>

' --- Sistema como actor secundario ---
SIS --> UC06 : verifica stock en BD
SIS --> UC07 : actualiza inventario
SIS --> UC12 : genera comprobante fiscal

' --- Actor Paciente (para ventas con receta) ---
PAC --> UC08 : presenta receta médica

@enduml
